  <DataSets>
    <DataSet Name="articulo">
      <Query>
        <DataSourceName>fuente</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@cod_articulo">
            <Value>=Parameters!cod_articulo.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select ArtCod as cod_articulo, 
    ArtNombre as nom_articulo, 
    ArtLineaDesc as nom_linea, 
    ArtTipoDesc as nom_tipo, 
    ArtSistRepDesc as sistema_reposicion,
    ArtCategoria as categoria,
    isnull(icc.icc,'Z') as icc
from VW_Articulo arts 
        left join aux_calculo_icc_articulo icc on icc.cod_articulo = arts.ArtCod
where arts.ArtCod = @cod_articulo</CommandText>
      </Query>
      <Fields>
        <Field Name="cod_articulo">
          <DataField>cod_articulo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nom_articulo">
          <DataField>nom_articulo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nom_linea">
          <DataField>nom_linea</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nom_tipo">
          <DataField>nom_tipo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="sistema_reposicion">
          <DataField>sistema_reposicion</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="categoria">
          <DataField>categoria</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="icc">
          <DataField>icc</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ventas">
      <Query>
        <DataSourceName>fuente</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@cod_articulo">
            <Value>=Parameters!cod_articulo.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select * from fnc_getventasarticulo_3a (@cod_articulo)</CommandText>
      </Query>
      <Fields>
        <Field Name="fecha">
          <DataField>fecha</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="anio">
          <DataField>anio</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="mes">
          <DataField>mes</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="nom_periodo">
          <DataField>nom_periodo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="venta_cantidad">
          <DataField>venta_cantidad</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="venta_dolares">
          <DataField>venta_dolares</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="costo_dolares">
          <DataField>costo_dolares</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="margen">
          <DataField>margen</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="top_clientes">
      <Query>
        <DataSourceName>fuente</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@cod_articulo">
            <Value>=Parameters!cod_articulo.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select top 5
    cli.ClienteCod as cod_cliente, 
    cli.ClienteDesc as razon_social,
    q.venta,
    q.ult_fecha_compra
from 
(
select ClienteCod as cod_cliente, sum(CompDetMonto) as venta, max(CompFecha) as ult_fecha_compra
from VW_VentasDet where CompDetArtCod = @cod_articulo
group by ClienteCod
) q 
inner join VW_Cliente cli on cli.ClienteCod = q.cod_cliente
order by q.venta desc</CommandText>
      </Query>
      <Fields>
        <Field Name="cod_cliente">
          <DataField>cod_cliente</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="razon_social">
          <DataField>razon_social</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="venta">
          <DataField>venta</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ult_fecha_compra">
          <DataField>ult_fecha_compra</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
