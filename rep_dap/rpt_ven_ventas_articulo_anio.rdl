  <DataSources>
    <DataSource Name="fuente">
      <DataSourceReference>bd_dap</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>a32ff1cb-cfa7-42b6-8228-49875ff9e6af</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="info">
      <Query>
        <DataSourceName>fuente</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@linea">
            <Value>=Parameters!linea.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@filtro_articulo">
            <Value>=Parameters!filtro_articulo.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 
    CompDetArtCod as cod_articulo, artnombre as nom_articulo,
    eomonth(CompFecha,0) as periodo,
    isnull(artlineadesc,'Sin Línea') as linea,
    SUM(
        CASE
            WHEN v.CompNCInd = 0 THEN  v.CompDetCant
            WHEN v.CompNCInd = 1 THEN -v.CompDetCant
            ELSE 0
        END
    ) as cantidad,
    sum(CompDetCant) as venta_cantidad,
    sum(CompDetMonto) as venta_dolares
from VW_VentasDet v
where year(CompFecha)=2025 
        and isnull(artlineadesc,'Sin Línea') like '%'+@linea+'%'
        and CompDetArtCod+lower(ArtNombre) like '%'+@filtro_articulo+'%'
group by 
    CompDetArtCod, artnombre,
    eomonth(CompFecha,0), isnull(artlineadesc,'Sin Línea')</CommandText>
      </Query>
      <Fields>
        <Field Name="cod_articulo">
          <DataField>cod_articulo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nom_articulo">
          <DataField>nom_articulo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="periodo">
          <DataField>periodo</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="linea">
          <DataField>linea</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="cantidad">
          <DataField>cantidad</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="venta_cantidad">
          <DataField>venta_cantidad</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="venta_dolares">
          <DataField>venta_dolares</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
