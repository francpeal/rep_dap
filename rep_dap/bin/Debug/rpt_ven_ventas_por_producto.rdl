  <DataSources>
    <DataSource Name="fuente">
      <DataSourceReference>bd_dap</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>09f17a64-88b2-4d30-a607-d302b217b1b0</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="info">
      <Query>
        <DataSourceName>fuente</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@filtro">
            <Value>=Parameters!filtro.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select top 15 
    cab.ClienteDoc as ruc, 
    cab.ClienteDesc as razon_social, 
    cab.CompFecha as fecha_emision, 
    cab.CompDocNumCompleto as folio,
    cab.ClienteTipoDesc as tipo_cliente,
    det.compdetartcod as cod_articulo, 
    det.CompDetCant as cantidad, 
    det.CompDetPrecio as precio_dolares,
    det.CompDetDescuento as porc_dscto,
    det.CompDetMonto as total_dolares,
    det.ArtLineaDesc as linea_articulo,
    det.ArtTipoDesc as tipo_articulo,
    det.ArtNombre as nom_articulo
from 
    VW_Ventas_Extended cab 
    inner join VW_VentasDet_Extended det on cab.CompDocNumCompleto = det.CompDocNumCompleto
where 
    det.CompDetArtCod + det.ArtNombre like '%'+@filtro+'%' </CommandText>
      </Query>
