  <DataSources>
    <DataSource Name="fuente">
      <DataSourceReference>bd_dap</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>7f186867-2b02-4928-a821-2ef069cc0b28</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="info">
      <Query>
        <DataSourceName>fuente</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@cod_vendedor">
            <Value>=Parameters!cod_vendedor.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select 
    ltrim(rtrim(b.DES_VEND)) as nom_vendedor,
    a.CDG_ALT ruc, 
    ltrim(rtrim(a.DES_CLI)) as razon_social,
    vtas.vta_anio_anterior,
    vtas.vta_anio_actual,
    a.dir_cli as direccion,
    isnull(a.tel_cli, a.fax_cli) as telefono,
    a.ema_cli as email,
    isnull(vta6.per,eomonth(getdate(),0)) as per,
    isnull(vta6.venta_mes,0) as venta_mes,
    cl.clientetipodesc as tipo_cliente, 
    cl.ubidist as distrito
from 
    m_client a 
    inner join M_VENDED b on a.CDG_VEND = b.CDG_VEND
    left join 
    (
        select 
            ClienteCod as cod_cliente,
            sum(case when year(CompFecha) = (year(getdate())-1) then compmonto else 0 end) as vta_anio_anterior,
            sum(case when year(CompFecha) = year(GETDATE()) then compmonto else 0 end) as vta_anio_actual
        from VW_Ventas 
        where year(compFecha) &gt;= year(getdate())-1
        group by clientecod
        having sum(CompMonto)&gt;0.1
    ) vtas on a.ruc_cli = vtas.cod_cliente
    left join 
    (
        select 
            ClienteCod as cod_cliente,
            -- year(CompFecha) as anio, 
            -- month(CompFecha) as mes,
            EOMONTH(compfecha,0) as per,
            sum(CompMonto) as venta_mes
        from VW_Ventas 
        where convert(date,CompFecha)&gt;=DATEADD(MONTH,-6,GETDATE())
        group by 
            ClienteCod,
            EOMONTH(compfecha,0)
        having sum(CompMonto)&gt;0
    ) vta6 on a.ruc_cli = vta6.cod_cliente
   left join vw_cliente cl on cl.ClienteCod = a.ruc_cli
where 
    a.cdg_vend = @cod_vendedor
    and isnull(a.CDG_ALT,'')&lt;&gt;''</CommandText>
      </Query>
      <Fields>
        <Field Name="nom_vendedor">
          <DataField>nom_vendedor</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ruc">
          <DataField>ruc</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="razon_social">
          <DataField>razon_social</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="vta_anio_anterior">
          <DataField>vta_anio_anterior</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="vta_anio_actual">
          <DataField>vta_anio_actual</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="direccion">
          <DataField>direccion</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="telefono">
          <DataField>telefono</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="email">
          <DataField>email</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="per">
          <DataField>per</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="venta_mes">
          <DataField>venta_mes</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="tipo_cliente">
          <DataField>tipo_cliente</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="distrito">
          <DataField>distrito</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="vendedores">
      <Query>
        <DataSourceName>fuente</DataSourceName>
        <CommandText>select 
    a.CDG_VEND as cod,
    ltrim(rtrim(b.DES_VEND)) as nom    
from m_client a 
    inner join M_VENDED b on a.CDG_VEND = b.CDG_VEND
group by a.cdg_vend, ltrim(rtrim(b.DES_VEND))
order by 2</CommandText>
      </Query>
      <Fields>
        <Field Name="cod">
          <DataField>cod</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nom">
          <DataField>nom</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
