  <DataSources>
    <DataSource Name="fuente">
      <DataSourceReference>bd_dap</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>bfee1376-9463-49b0-b583-96004b64a31b</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="info">
      <Query>
        <DataSourceName>fuente</DataSourceName>
        <CommandText>select isnull(CompPedVenDesc, 'Sin vendedor') as vendedor, eomonth(CompFecha,0) as periodo,
    compmonto as venta_dolares
from vw_ventas 
where CompFecha &gt; DATEADD(MONTH,-12,EOMONTH(GETDATE(),0))</CommandText>
      </Query>
      <Fields>
        <Field Name="vendedor">
          <DataField>vendedor</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="periodo">
          <DataField>periodo</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="venta_dolares">
          <DataField>venta_dolares</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
