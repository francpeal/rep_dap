  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="fuente">
      <DataSourceReference>bd_dap</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>e6b6ac26-311f-4518-8a05-82dc00cec173</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="fuente">
      <Query>
        <DataSourceName>fuente</DataSourceName>
        <CommandText>
select 
    b.cdg_vend as cod_vendedor,
    ltrim(rtrim(b.DES_VEND)) as nom_vendedor,
    isnull(nc.nro_clientes,0) as nro_clientes,
    isnull(vta.anio,year(GETDATE())) as anio, 
    isnull(vta.mes, month(getdate())) as mes,
    sum(isnull(venta_mes,0)) as venta    
from 
    m_client a 
    inner join M_VENDED b on a.CDG_VEND = b.CDG_VEND    
    left join 
    (
        select 
            ClienteCod as cod_cliente,
            year(compfecha) as anio, 
            month(compfecha) as mes,
            sum(CompMonto) as venta_mes
        from VW_Ventas 
        where 
                year(CompFecha)&gt;=2025
        group by 
            ClienteCod, year(compfecha), month(compfecha)
        having sum(CompMonto)&gt;0
    ) vta on a.ruc_cli = vta.cod_cliente
    left join 
    (
        select cdg_vend as cod_vendedor, count(distinct ruc_cli) as nro_clientes
        from M_CLIENT
        group by cdg_vend 
    ) nc on b.CDG_VEND = nc.cod_vendedor
where 
    isnull(a.CDG_ALT,'')&lt;&gt;''
group by 
    b.cdg_vend,
    ltrim(rtrim(b.DES_VEND)),
    isnull(nc.nro_clientes,0),
    isnull(vta.anio,year(GETDATE())),
    isnull(vta.mes, month(getdate()))</CommandText>
      </Query>
      <Fields>
        <Field Name="cod_vendedor">
          <DataField>cod_vendedor</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nom_vendedor">
          <DataField>nom_vendedor</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="nro_clientes">
          <DataField>nro_clientes</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="anio">
          <DataField>anio</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="mes">
          <DataField>mes</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="venta">
          <DataField>venta</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
